# ────────────────────────────────────────────────────────────────────────
# Pulse Terminal · environment template
# Copy to .env.local (which is gitignored) and fill in only what you need.
# Per-app env vars override these — defaults below are sane for local dev.
# ────────────────────────────────────────────────────────────────────────

# ── Realtime / Hub (apps/realtime) ──────────────────────────────────────
# WebSocket server (consumed by apps/web Derivatives tab)
WS_PORT=8080
WS_HOST=localhost

# Hub HTTP cache server (Phase B v0 — consumed by apps/mcp + apps/web /api/health)
HUB_HTTP_PORT=8081

# Comma-separated list of native exchange WS streams to enable.
# Set to empty string to fall back to REST polling only.
PULSE_NATIVE_STREAMS=binance,bybit,okx

# ── Web (apps/web) ──────────────────────────────────────────────────────
# WebSocket URL the browser connects to
NEXT_PUBLIC_WS_URL=ws://localhost:8080

# Hub URL the Next.js server-side routes query for /api/health
PULSE_HUB_URL=http://127.0.0.1:8081

# ── Alerts (apps/alerts) ────────────────────────────────────────────────
# How often to scan for anomalies (ms). Default 4 min — tighter cadence so the
# JSONL log fills faster for Phase 4 graded backtest replay.
ALERT_INTERVAL_MS=240000

# Where to append the JSONL log (read by /api/backtest)
ALERT_LOG_PATH=./apps/alerts/data/alerts.jsonl

# Minimum severity that triggers webhook + console summary
# low | med | high
ALERT_MIN_SEVERITY=med

# Symbol passed to detect_anomalies() funding check
ALERT_FUNDING_SYMBOL=BTCUSDT

# Optional Discord/Slack incoming webhook URL.
# Leave empty to log to stdout only.
ALERT_WEBHOOK_URL=

# ── Optional: portfolio sync (Binance signed) ───────────────────────────
# Use a READ-ONLY key — disable Trading + Withdrawal in Binance API console.
# Without these, /api/portfolio returns { configured: false } (not an error).
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ── Optional: Bybit Dual Assets (place-order only, NOT required for tracking) ─
# Bybit launched Advanced-Earn DualAssets API on 2026-03-24, switching the
# product/quote endpoints to public (no auth). The current tracker reads only
# public data, so leaving these blank does NOT disable the cron.
# These are only consumed if/when place-order is implemented (writeable scope).
# If you do set them, use a READ-ONLY key (disable Trading + Withdrawal).
BYBIT_API_KEY=
BYBIT_API_SECRET=

# ── ETF flows ────────────────────────────────────────────────────────────
# Farside is the primary source (free public scrape via curl-impersonate).
# COINGLASS_API_KEY removed 2026-05-01 — user decision: free sources only.

# ── Optional: Anthropic API ─────────────────────────────────────────────
# Used by the morning brief (apps/alerts) for LLM-generated action candidates
# (claude-haiku-4-5, ~1 call/day, in-memory cached by date+regime). Falls back
# to rules-based suggestions when missing.
# Also needed if you re-enable the legacy in-browser /api/analyze panel.
ANTHROPIC_API_KEY=

# ── Morning Brief Telegram (apps/alerts) ────────────────────────────────
# Daily ETF + macro regime push at 09:00 Asia/Bangkok, Mon-Fri.
# Opt-in: leaving TELEGRAM_BOT_TOKEN empty disables the cron entirely.
#
# Setup: see apps/alerts/src/morning-brief/README.md
#  1. Talk to @BotFather on Telegram → /newbot → grab the HTTP API token
#  2. Send /start to your new bot from your account
#  3. Visit https://api.telegram.org/bot<TOKEN>/getUpdates → copy chat.id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Inline-keyboard "Open Dashboard" button target. Defaults to localhost.
PULSE_DASHBOARD_URL=http://localhost:3000/morning
