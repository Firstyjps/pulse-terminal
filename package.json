{
  "name": "pulse-terminal",
  "version": "0.1.0",
  "private": true,
  "description": "Crypto Macro Intelligence Terminal — monorepo merging 4 prior projects",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "pulse:build": "pnpm --filter @pulse/web build",
    "pulse:start": "pm2 start ecosystem.config.cjs",
    "pulse:stop": "pm2 stop ecosystem.config.cjs",
    "pulse:restart": "pm2 restart ecosystem.config.cjs",
    "pulse:status": "node scripts/pulse-status.mjs",
    "pulse:logs": "pm2 logs --lines 50"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.2"
  }
}
